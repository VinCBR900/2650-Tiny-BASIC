13C1  0520    :        LODI,R1 SP
13C3  01      :        LODZ,R1
13C4  3F02B4  :        BSTA,UN COUT
13C7  0508    :        LODI,R1 BS
13C9  01      :        LODZ,R1
13CA  3F02B4  :        BSTA,UN COUT
13CD  1F135B  :        BCTA,UN RL_LP
              :RL_EOL:
