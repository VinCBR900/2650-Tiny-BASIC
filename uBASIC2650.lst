              :; ─── STORE_LINE ───────────────────────────────────────────────────────────────
              :; Insert line LNUMH:LNUML with body at IP into program store (sorted).
              :; Record format: [linehi][linelo][bodylen][body...]
              :; Strategy: delete existing line, measure body, check space, find insertion
              :;           point (EXPH:EXPL), shift existing records up, write new record.
              :STORE_LINE:
09A3  3F0ADC  :        BSTA,UN DELETE_LINE              ; [+1]  remove if exists

              :        ; measure body length: walk from IP to NUL, count in R3
09A6  0C1400  :        LODA,R0 IPH
09A9  CC1412  :        STRA,R0 TMPH
09AC  0C1401  :        LODA,R0 IPL
09AF  CC1413  :        STRA,R0 TMPL  ; TMPH:TMPL = body start (save for write)
09B2  0700    :        LODI,R3 0
              :SL_MEAS:
09B4  0C9412  :        LODA,R0 *TMPH
09B7  E400    :        COMI,R0 NUL
09B9  1C09C1  :        BCTA,EQ SL_MEASD
09BC  3F1451  :        BSTA,UN INC_TMP
              :SL_MNC:
09BF  DB73    :        BIRR,R3 SL_MEAS         ; R3++ then always branch (counts: 0→1→2...)
              :SL_MEASD:
              :        ; R3 = body length.  SC0 = body len.  SC1 = record size = 3 + R3.
09C1  CF140C  :        STRA,R3 SC0
09C4  0C140C  :        LODA,R0 SC0
09C7  8403    :        ADDI,R0 3
09C9  CC140D  :        STRA,R0 SC1

              :        ; check free space: PROGLIM - PE >= SC1
09CC  041C    :        LODI,R0 <PROGLIM
09CE  AC1403  :        SUBA,R0 PEL
09D1  CC1413  :        STRA,R0 TMPL
09D4  0400    :        LODI,R0 >PROGLIM
09D6  AC1402  :        SUBA,R0 PEH
09D9  9E09DE  :        BCFA,LT SL_NBC
09DC  A401    :        SUBI,R0 1  ; borrow skip: BCFA,LT
              :SL_NBC:
09DE  CC1412  :        STRA,R0 TMPH            ; TMPH:TMPL = free bytes
09E1  0C1412  :        LODA,R0 TMPH
09E4  E400    :        COMI,R0 $00
09E6  1D09F7  :        BCTA,GT SL_ROOM
09E9  0C1413  :        LODA,R0 TMPL
09EC  AC140D  :        SUBA,R0 SC1
09EF  9E09F7  :        BCFA,LT SL_ROOM  ; free >= needed?
09F2  0403    :        LODI,R0 3
09F4  1F148D  :        BCTA,UN DO_ERROR  ; out of memory

              :SL_ROOM:
              :        ; find sorted insertion point → EXPH:EXPL
09F7  3F0BD9  :        BSTA,UN FIND_INS                 ; [+1]  sets TMPH:TMPL
              :        ; save insertion point in EXPH:EXPL (TMPH:TMPL will be used as walk pointer)
09FA  0C1412  :        LODA,R0 TMPH
09FD  CC1410  :        STRA,R0 EXPH
0A00  0C1413  :        LODA,R0 TMPL
0A03  CC1411  :        STRA,R0 EXPL

              :        ; shift bytes PE-1 down to EXPH:EXPL upward by SC1 positions (backwards copy)
              :        ; shift count = PE - EXPH:EXPL
0A06  0C1403  :        LODA,R0 PEL
0A09  AC1411  :        SUBA,R0 EXPL
0A0C  CC1413  :        STRA,R0 TMPL
0A0F  0C1402  :        LODA,R0 PEH
0A12  AC1410  :        SUBA,R0 EXPH
0A15  9E0A1A  :        BCFA,LT SL_SHCNB
0A18  A401    :        SUBI,R0 1
              :SL_SHCNB:
0A1A  CC1412  :        STRA,R0 TMPH            ; TMPH:TMPL = shift count

              :        ; if shift count == 0 skip loop
0A1D  0C1412  :        LODA,R0 TMPH
0A20  E400    :        COMI,R0 $00
0A22  1D0A2D  :        BCTA,GT SL_DOSHIFT
0A25  0C1413  :        LODA,R0 TMPL
0A28  E400    :        COMI,R0 $00
0A2A  1C0A8A  :        BCTA,EQ SL_NOSHIFT
              :SL_DOSHIFT:
              :        ; src = PE-1 in NEGFLG:SC1 (use two scratch bytes; LNUMH:LNUML free now)
0A2D  0C1403  :        LODA,R0 PEL
0A30  A401    :        SUBI,R0 1
0A32  CC140B  :        STRA,R0 LNUML
0A35  0C1402  :        LODA,R0 PEH
0A38  9E0A3D  :        BCFA,LT SL_SNBR
0A3B  A401    :        SUBI,R0 1
              :SL_SNBR:
0A3D  CC140A  :        STRA,R0 LNUMH           ; LNUMH:LNUML = src = PE-1
              :        ; dst = src + SC1  → SC0 now holds body len not record size! Use SC1.
              :        ; Actually SC1 = record size = shift amount.
0A40  0C140B  :        LODA,R0 LNUML
0A43  8C140D  :        ADDA,R0 SC1
