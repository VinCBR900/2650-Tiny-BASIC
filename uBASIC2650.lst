              :; ─── GETKEY ───────────────────────────────────────────────────────────────────
              :; Blocking keyboard read via Pipbug CHIN (non-blocking).
              :; Spins until a key is available.  Returns char in R0.
              :; Clobbers R0 only.  RAS cost: +1 for CHIN call (net 0 at return).
              :GETKEY:
1348  3F0286  :        BSTA,UN CHIN            ; R0 = key, or 0 if no key ready
134B  E400    :        COMI,R0 $00
134D  1C1348  :        BCTA,EQ GETKEY          ; spin until non-zero
1350  17      :        RETC,UN

              :; ─── RDLINE ───────────────────────────────────────────────────────────────────
              :; Read a line from input into IBUF, echo with backspace support. NUL-terminates.
              :; Uses GETKEY (via CHIN) for blocking input. Char received in R0 at each step;
              :; saved to R1 for storage/echo so R0 is free for pointer arithmetic.
              :RDLINE:
1351  0440    :        LODI,R0 >IBUF
1353  CC1400  :        STRA,R0 IPH
1356  0414    :        LODI,R0 <IBUF
1358  CC1401  :        STRA,R0 IPL
              :RL_LP:
135B  3F1348  :        BSTA,UN GETKEY          ; [+1] blocking — R0 = char
135E  C1      :        STRZ,R1                 ; R1 = R0 (char  ; R0 now free for pointer arithmetic)
135F  E50D    :        COMI,R1 CR
1361  1C13D0  :        BCTA,EQ RL_EOL
1364  E50A    :        COMI,R1 LF
1366  1C13D0  :        BCTA,EQ RL_EOL
1369  E508    :        COMI,R1 BS
136B  1C1393  :        BCTA,EQ RL_BS
              :        ; buffer full?  IP >= IBUF+63
136E  0C1400  :        LODA,R0 IPH
1371  AC0040  :        SUBA,R0 >IBUF
1374  1D1383  :        BCTA,GT RL_FULL
1377  1E1386  :        BCTA,LT RL_STORE
137A  0C1401  :        LODA,R0 IPL
137D  AC0014  :        SUBA,R0 <IBUF+63
1380  1E1386  :        BCTA,LT RL_STORE
              :RL_FULL:
1383  1F135B  :        BCTA,UN RL_LP
              :RL_STORE:
1386  CD9400  :        STRA,R1 *IPH            ; store char to buffer
1389  01      :        LODZ,R1
138A  3F02B4  :        BSTA,UN COUT            ; echo char
138D  3F143D  :        BSTA,UN INC_IP
1390  1F135B  :        BCTA,UN RL_LP
              :RL_BS:
              :        ; at IBUF start? — no backspace if buffer empty
1393  0C1400  :        LODA,R0 IPH
1396  AC0040  :        SUBA,R0 >IBUF
1399  1D13A8  :        BCTA,GT RL_BSDO
139C  1E135B  :        BCTA,LT RL_LP
139F  0C1401  :        LODA,R0 IPL
13A2  AC0014  :        SUBA,R0 <IBUF
13A5  1C135B  :        BCTA,EQ RL_LP
              :RL_BSDO:
13A8  0C1401  :        LODA,R0 IPL
13AB  A401    :        SUBI,R0 1
13AD  CC1401  :        STRA,R0 IPL
13B0  9E13BB  :        BCFA,LT RL_BSNB
13B3  0C1400  :        LODA,R0 IPH
13B6  A401    :        SUBI,R0 1
13B8  CC1400  :        STRA,R0 IPH
              :RL_BSNB:
