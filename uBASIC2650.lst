13D7  01      :        LODZ,R1
13D8  3F02B4  :        BSTA,UN COUT
13DB  050A    :        LODI,R1 LF
13DD  01      :        LODZ,R1
13DE  3F02B4  :        BSTA,UN COUT
13E1  17      :        RETC,UN

